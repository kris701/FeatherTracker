<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
	  <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

	<ItemGroup>
		<PackageReference Include="DatabaseSharp" Version="1.6.4" />
		<PackageReference Include="Uni.API" Version="1.2.2" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\..\FeatherTracker.API.Endpoints\FeatherTracker.API.Endpoints.csproj" />
		<ProjectReference Include="..\..\..\FeatherTracker.API.Tools\FeatherTracker.API.Tools.csproj" />
		<ProjectReference Include="..\..\COR\FeatherTracker.Plugins.COR\FeatherTracker.Plugins.COR.csproj" />
	</ItemGroup>

	<Target Name="PostBuild" AfterTargets="PostBuildEvent">
		<Exec Command="dotnet cs2ts --output &quot;../../../../FrontEnd/src/app/models/WGT&quot; --clear-output-directory --convert-dates-to &quot;Union&quot; --import-generation &quot;Simple&quot; &quot;../../../FeatherTracker.API.Tools/BaseExecIDModel.cs&quot;" ContinueOnError="true" />
		<Exec Command="dotnet cs2ts --output &quot;../../../../FrontEnd/src/app/models/WGT&quot; --convert-dates-to &quot;Union&quot; --import-generation &quot;Simple&quot; &quot;./Models/Shared/&quot;" ContinueOnError="true" />
	</Target>

</Project>
